# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Housing ML Model Service
# Files and folders that should NOT be committed to Git
# ──────────────────────────────────────────────────────────────────────────────

# Python virtual environment
venv/
.venv/
env/

# Python bytecode cache (auto-generated by Python, not source code)
__pycache__/
*.py[cod]
*.pyo

# Trained model file (large binary file — regenerated by train_model.py)
model.pkl

# Metrics file (regenerated by train_model.py)
metrics.json

# Environment variables (may contain secrets in future)
.env

# IDE / editor
.vscode/
.idea/
*.swp

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Distribution / packaging
dist/
build/
*.egg-info/
