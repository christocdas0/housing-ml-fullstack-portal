{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Model Service (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "python": "E:/pyenvs/housing_ml/Scripts/python.exe",
      "cwd": "${workspaceFolder}/model-service",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/model-service"
      },
      "jinja": true
    },
    {
      "name": "Next.js Portal (dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/portal/nextjs-portal",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "started server on .+, url: (https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
